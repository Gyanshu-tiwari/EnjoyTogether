# Express server port configuration
PORT=5000

# Telegram Bot configurations (used for notification alerts, etc.)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=your_telegram_channel_id_here

# Telegram MTProto Client credentials (used for media chunk streaming)
TELEGRAM_API_ID=your_telegram_api_id_here
TELEGRAM_API_HASH=your_telegram_api_hash_here
TELEGRAM_SESSION=your_telegram_session_string_here

# LiveKit SFU configurations (used for WebRTC floating video call overlay)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Supabase Configurations (optional: used for DB data access layer state sync)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
